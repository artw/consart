#!/usr/bin/env -S zsh -f

local name="${1:?usage: proj <name>}"
local base=~/Sync/code

# find project dir: exact match at top level or one level deep
local dir
dir=$(find "$base" -mindepth 1 -maxdepth 2 -type d -name "$name" 2>/dev/null | head -1)

if [[ -z $dir ]]; then
  echo "proj: no project '$name' found under $base" >&2
  return 1
fi

# sanitize session name (tmux dislikes dots and slashes)
local session="${name//[.\/]/-}"

# attach if session exists
if tmux has-session -t "$session" 2>/dev/null; then
  tmux attach -t "$session"
  return
fi

# create session with first window in project dir (blank shell)
tmux new-session -d -s "$session" -c "$dir" -x 220 -y 50

# capture the initial pane ID (avoids base-index assumptions)
local first_pane
first_pane=$(tmux display-message -t "$session" -p '#{pane_id}')

# split horizontally: right pane gets pi -r
tmux split-window -h -t "$first_pane" -c "$dir" "pi -r"

# split left pane vertically: bottom pane = blank shell
local shell_pane
shell_pane=$(tmux split-window -v -t "$first_pane" -c "$dir" -P -F '#{pane_id}')

# send lazygit to top-left (original) pane
tmux send-keys -t "$first_pane" "lazygit" Enter

# select the shell pane (bottom-left)
tmux select-pane -t "$shell_pane"

tmux attach -t "$session"
