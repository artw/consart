#compdef de

_de() {
  local -a boxes
  if iscmd distrobox; then
    boxes=( ${(f)"$(distrobox list --no-color | tail -n +2 | awk -F'|' '{gsub(/^ +| +$/, "", $2); print $2}')"} )
    _describe 'distrobox container' boxes
  elif iscmd docker; then
    _arguments '*:container:_docker_complete_running_containers'
  fi
}

_de "$@"
