#!/usr/bin/env -S zsh -f

if [[ "$1" == "-l" ]]; then
  tmux list-sessions 2>/dev/null || echo "no sessions"
  return
fi

local session="${1:-${HOSTNAME:-$(hostname -s)}}"
if [[ -n "$DISTROBOX" ]] && command -v distrobox &>/dev/null; then
  # Called from host — enter the distrobox and attach/create tmux there
  cd ~; distrobox enter "$DISTROBOX" -- tmux attach -t "$session" 2>/dev/null \
    || distrobox enter "$DISTROBOX" -- tmux new-session -s "$session"
else
  # Either no DISTROBOX set, or already inside a distrobox (distrobox not in PATH)
  cd ~; tmux attach -t "$session" 2>/dev/null \
    || tmux new-session -s "$session"
fi
