#!/usr/bin/env zsh -f

local session="${1:-${HOSTNAME:-$(hostname -s)}}"
if [[ -n "$DISTROBOX" ]]; then
  cd ~; distrobox enter "$DISTROBOX" -- tmux attach -t "$session" 2>/dev/null \
    || distrobox enter "$DISTROBOX" -- tmux new-session -s "$session"
else
  cd ~; tmux attach -t "$session" 2>/dev/null \
    || tmux new-session -s "$session"
fi
